# Python virtual environment
.venv/
venv/

# Python-generated files
__pycache__/
*.py[cod]
*$py.class
*.so

# Packaging
build/
dist/
*.egg-info/

# Environment variables and secrets
.env
.env.*
!.env.example

# VS Code local settings
.vscode/
*.code-workspace

# Jupyter
.ipynb_checkpoints/

# macOS
.DS_Store

# Test and tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Logs
*.log
logs/

# Raw and generated datasets
data/raw/*
data/interim/*
data/processed/*
data/splits/*

# Keep directory placeholders
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep
!data/splits/.gitkeep

# Trained models and checkpoints
models/checkpoints/*
models/adapters/*
models/final/*

# Keep model directory placeholders
!models/checkpoints/.gitkeep
!models/adapters/.gitkeep
!models/final/.gitkeep

# Generated reports
reports/figures/*
reports/metrics/*
reports/error_analysis/*

# Keep report directory placeholders
!reports/figures/.gitkeep
!reports/metrics/.gitkeep
!reports/error_analysis/.gitkeep